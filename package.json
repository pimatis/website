{
	"name": "pimatis-web",
	"version": "1.0.0",
	"description": "Pimatis Website is a modern web application built using SvelteKit and styled with Tailwind CSS.",
	"private": false,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"tailwindcss",
		"pimatis",
		"pimatis website",
		"team website",
		"team",
		"opensource"
	],
	"author": "Pimatis",
	"license": "MIT",
	"homepage": "https://github.com/pimatis/pimatis-web#readme",
	"bugs": {
		"url": "https://github.com/pimatis/pimatis-web/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/pimatis/pimatis-web.git"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"autoprefixer": "^10.4.20",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.9",
		"typescript": "^5.0.0",
		"vite": "^6.0.0"
	}
}
